# Boutique Store Management System - Environment Configuration
# Copy this file to .env and update values for your local environment

# ============================================
# APPLICATION CONFIGURATION
# ============================================
APP_NAME=BoutiqueStoreManagement
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=UTC

# ============================================
# DATABASE CONFIGURATION
# ============================================
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=boutique_store_db
DB_USER=root
DB_PASSWORD=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# ============================================
# SESSION CONFIGURATION
# ============================================
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_SECURE_ONLY=false
SESSION_HTTP_ONLY=true

# ============================================
# SECURITY CONFIGURATION
# ============================================
APP_KEY=your-secret-key-here-change-in-production
PASSWORD_HASH_ALGO=bcrypt
PASSWORD_HASH_COST=12

# ============================================
# LOGGING CONFIGURATION
# ============================================
LOG_CHANNEL=single
LOG_LEVEL=debug
LOG_PATH=/storage/logs

# ============================================
# CACHE CONFIGURATION
# ============================================
CACHE_DRIVER=file
CACHE_PATH=/storage/cache

# ============================================
# MAIL CONFIGURATION (OPTIONAL)
# ============================================
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=465
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=noreply@boutique.local
MAIL_FROM_NAME=BoutiqueStore

# ============================================
# DEVELOPER SETTINGS
# ============================================
DEVELOPER_EMAIL=developer@boutique.local
ENABLE_QUERY_LOGGING=false
ENABLE_PERFORMANCE_LOGGING=false
