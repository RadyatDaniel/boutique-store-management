{
    "name": "boutique-store/management-system",
    "description": "A comprehensive web-based management system for boutique stores",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Development Team",
            "email": "dev@boutique.local"
        }
    ],
    "require": {
        "php": ">=8.0",
        "ext-mysqli": "*",
        "ext-pdo": "*",
        "ext-json": "*",
        "ext-filter": "*",
        "ext-hash": "*",
        "ext-bcmath": "*"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.95",
        "phpstan/phpstan": "^1.10",
        "phpunit/phpunit": "^10.0",
        "squizlabs/php_codesniffer": "^3.9"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Tests\\": "tests/"
        },
        "files": [
            "config/config.php"
        ]
    },
    "scripts": {
        "test": "phpunit",
        "test:coverage": "phpunit --coverage-html coverage/",
        "lint": "phpcs --standard=PSR12 app/ config/ routes/",
        "lint:fix": "phpcbf --standard=PSR12 app/ config/ routes/",
        "analyze": "phpstan analyse app/ config/",
        "psalm": "psalm"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}
